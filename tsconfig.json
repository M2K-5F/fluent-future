{
    "compilerOptions": {
        "target": "ES2021",
        "module": "CommonJS",
        "declaration": true,      
        "declarationMap": true,   
        "outDir": "./dist",
        "rootDir": "./src",       
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": ["src/**/*", "tests"],
    "exclude": ["node_modules", "**/tests/*"]
}